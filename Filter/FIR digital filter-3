% 用等波纹最佳逼近法设计滤波器
fb=[fp,fs];
m=[1,0];        
dev=[(10^(Rp/20)-1)/(10^(Rp/20)+1),10^(-As/20)];
[Ne,fo,mo,W]=remezord(fb,m,dev,Fs);
hn=remez(Ne,fo,mo,W);
Hw=abs(fft(hn,1024));
yet=fftfilt(hn,xt,N);
f=(0:1023)*Fs/1024;
figure(3);
plot(f,20*log10(Hw/max(Hw)),'g');
grid;
title('等波纹法的低通滤波器幅频特性');
axis([0,Fs/2,-80,10]);
xlabel('f/Hz');
ylabel('幅度')
t=(0:N-1)/Fs;
Tp=N/Fs;
plot(t,yet,'r');
grid;
axis([0,Tp/2,-1,1]);
xlabel('t/s');
ylabel('y_e(t)');
title('滤除噪声后的信号波形');

